NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
TRUST_PROXY_HOPS=0
WEB_BIND_ADDRESS=127.0.0.1
API_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_BIND_ADDRESS=127.0.0.1
REDIS_BIND_ADDRESS=127.0.0.1
MINIO_BIND_ADDRESS=127.0.0.1
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PROXY_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

POSTGRES_DB=agent_platform
POSTGRES_USER=agent_platform
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://agent_platform:REPLACE_ME@localhost:5432/agent_platform?schema=public

REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
# Only for a private in-cluster MinIO hostname such as "minio". Keep false for external S3.
S3_ALLOW_INSECURE_INTERNAL_ENDPOINT=false
S3_REGION=us-east-1
S3_BUCKET=agent-platform
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Development-only 32-byte key. Generate a unique value before any shared or production deployment.
ENCRYPTION_KEY=
COOKIE_SECURE=false
BOOTSTRAP_TOKEN=
OLLAMA_ALLOWED_BASE_URLS=http://localhost:11434/v1,http://127.0.0.1:11434/v1
# Optional exact HTTPS origins for deployment-controlled Bedrock proxies. Empty is safest.
BEDROCK_ALLOWED_ENDPOINTS=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_NAME=Platform Administrator
DEFAULT_ORGANIZATION_NAME=Acme Corporation
DEFAULT_WORKSPACE_NAME=AI Operations

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
