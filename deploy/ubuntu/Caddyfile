{
	admin off
	email {$ACME_EMAIL}
}

{$DEPLOY_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	handle /api/v1/* {
		reverse_proxy api:4000 {
			flush_interval -1
		}
	}

	handle {
		reverse_proxy web:3000
	}
}
